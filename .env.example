# Copy this file to ".env" (same folder) and fill in values.
# In dev: place at repo root.
# In a packaged install: place next to the installed .exe (or in the resources folder).

# Hugging Face access token, required for pyannote diarization model downloads.
# Get one at: https://huggingface.co/settings/tokens
# You must also accept the pyannote model license once on Hugging Face.
HUGGINGFACE_TOKEN=

# Optional: path to a specific Python executable. Defaults to "python" on PATH.
# WHISPER_PYTHON=C:\Path\To\python.exe
