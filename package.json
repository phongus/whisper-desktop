{
  "name": "whisper-desktop",
  "private": false,
  "version": "1.0.4",
  "description": "Electron desktop app for local Whisper transcription using Transformers.js",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "electron:dev": "concurrently \"vite --port 5174\" \"wait-on -t 10000 http-get://localhost:5174 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "vite build && electron-builder --win",
    "clean": "rm -rf node_modules/ dist/",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src/**/*.{js,jsx,ts,tsx,json}",
    "lint:fix": "eslint --fix src/**/*.{js,jsx,ts,tsx,json}",
    "format": "prettier --write src/**/*.{js,jsx,ts,tsx,css,md,json} --config ./.prettierrc",
    "tsc": "tsc"
  },
  "dependencies": {
    "@headlessui/react": "^1.7.13",
    "@xenova/transformers": "^2.7.0",
    "axios": "^1.3.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.28",
    "@types/react-dom": "^18.0.11",
    "@typescript-eslint/eslint-plugin": "^5.57.0",
    "@typescript-eslint/parser": "^5.57.0",
    "@vitejs/plugin-react": "^3.1.0",
    "autoprefixer": "^10.4.14",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "eslint": "^8.37.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-config-standard-with-typescript": "^34.0.1",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-n": "^15.7.0",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-promise": "^6.1.1",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "postcss": "^8.4.21",
    "prettier": "^2.8.7",
    "tailwindcss": "^3.2.7",
    "typescript": "^5.9.3",
    "vite": "^4.2.0",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.whisper.desktop",
    "productName": "Whisper Desktop",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "icon": "public/icon.ico",
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "keywords": [
    "electron",
    "react",
    "whisper",
    "speech-to-text",
    "transcription",
    "transformers.js"
  ],
  "author": "Phong Tran",
  "license": "MIT",
  "overrides": {
    "semver": "^7.5.3",
    "protobufjs": "^7.2.4",
    "sharp": "file:./stubs/sharp"
  }
}
